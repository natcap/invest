msgid "LULC codes from the LULC raster. Each code must be a unique integer."
msgstr "Código LULC del ráster LULC. Cada código debe ser un número entero único."

#: src/natcap/invest/spec.py:2331
msgid "area of interest"
msgstr "área de interés"

#: src/natcap/invest/spec.py:2333
msgid "A map of areas over which to aggregate and summarize the final results."
msgstr "Un mapa de zonas sobre el que agregar y resumir los resultados finales."

