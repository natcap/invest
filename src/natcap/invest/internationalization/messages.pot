#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:200
msgid ""
"\n"
"    The Coastal Vulnerability model calculates a coastal exposure index,\n"
"    which represents the relative exposure of different coastline segments\n"
"    to erosion and inundation caused by storms within the region of interest.\n"
"    The index values range from 1 (least exposed) to 5 (most exposed) and\n"
"    are calculated as the geometric mean of up to seven bio-geophysical\n"
"    variables.\n"
"    "
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:211
msgid "Coastal Vulnerability"
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:242
msgid "Map of the region over which to run the model."
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:248
msgid "model resolution"
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:249
msgid "Interval at which to space shore points along the coastline."
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:255
msgid "landmasses"
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:257
msgid "Map of all landmasses in and around the region of interest. It is not recommended to clip this landmass to the AOI polygon because some functions in the model require searching for landmasses around shore points up to the distance defined in Maximum Fetch Distance, which likely extends beyond the AOI polygon."
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:269
msgid "WaveWatchIII"
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:271
msgid "Map of gridded wind and wave data that represent storm conditions. This global dataset is provided with the InVEST sample data. There are 80 required columns; each of the 5 types is repeated for each sixteenth sector of the 360° compass: [0,22,45,67,90,112,135,157,180,202,225,247,270,292,315,337]. For example: REI_PCT0, V10PCT_90."
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:327
msgid "maximum fetch distance"
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:328
msgid ""
"\n"
"                The maximum fetch distance parameter can be used to control\n"
"                which shore points are exposed to open ocean waves. The value\n"
"                is the maximum distance in meters to extend rays from shore points.\n"
"                Points with rays equal to this distance accumulate ocean-driven\n"
"                wave energy along those rays. Local-wind-driven wave energy\n"
"                is accumulated along all rays.\n"
"                "
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:341
msgid "Bathymetry"
msgstr ""

#: src/natcap/invest/coastal_vulnerability/coastal_vulnerability.py:343
msgid "Map of bathymetry (ocean depth). Bathymetry values should be negative, and any positive values will be ignored. This should cover the area extending beyond the AOI to the maximum fetch distance."
